    {
      "name": "🔧 Utils",
      "item": [
        {
          "name": "Get 2FA Code from DB (run in terminal)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Run this command in terminal to get 2FA code:\n\ndocker exec cyna-postgres psql -U cyna -d cyna_db -c \"SELECT code, expires_at FROM admin_2fa_codes WHERE admin_id = (SELECT id FROM admins WHERE email = 'admin@cyna.io') ORDER BY created_at DESC LIMIT 1;\""
          }
        }
      ]
