                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tempToken\": \"{{tempToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/auth/admin/resend-2fa",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "auth", "admin", "resend-2fa"]
            },
            "description": "Resend the 2FA verification code. Returns a new tempToken. Rate limited to 3 req/5min."
          },
          "response": []
        },
        {
          "name": "Admin Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.accessToken) {",
                  "        pm.environment.set('accessToken', json.accessToken);",
                  "        pm.environment.set('tokenExpiresAt', String(Date.now() + (json.expiresIn * 1000)));",
                  "    }",
                  "    pm.test('Admin token refreshed', () => pm.response.to.have.status(200));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/auth/admin/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "auth", "admin", "refresh-token"]
            },
            "description": "Refresh admin access token. Reads refresh token from HTTP-only cookie. Rate limited to 10 req/min."
          },
          "response": []
        },
        {
          "name": "Admin Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.environment.set('accessToken', '');",
                  "    pm.environment.set('refreshToken', '');",
                  "    pm.environment.set('tempToken', '');",
                  "    pm.environment.set('tokenExpiresAt', '0');",
                  "    pm.test('Admin logout successful', () => pm.response.to.have.status(200));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/auth/admin/logout",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "auth", "admin", "logout"]
            },
            "description": "Admin logout. Requires Bearer token. Clears admin refresh token cookie. Rate limited to 5 req/min."
          },
          "response": []
        }
      ],
      "description": "Admin authentication with 2-step login (credentials + 2FA code)."
    },
