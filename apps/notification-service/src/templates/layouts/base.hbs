<!DOCTYPE html>
<html lang="{{language}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CYNA</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.6;
      color: #1a1a2e;
      margin: 0;
      padding: 0;
      background-color: #f5f5f7;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    .card {
      background-color: #ffffff;
      border-radius: 12px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      padding: 40px;
    }
    .header {
      text-align: center;
      margin-bottom: 30px;
    }
    .logo {
      font-size: 32px;
      font-weight: 700;
      color: #6366f1;
      text-decoration: none;
      letter-spacing: -1px;
    }
    .content {
      margin-bottom: 30px;
    }
    h1 {
      color: #1a1a2e;
      font-size: 24px;
      margin-bottom: 20px;
    }
    p {
      margin-bottom: 16px;
      color: #4a4a68;
    }
    .button {
      display: inline-block;
      background-color: #6366f1;
      color: #ffffff !important;
      padding: 14px 32px;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 600;
      margin: 20px 0;
    }
    .button:hover {
      background-color: #4f46e5;
    }
    .code-box {
      background-color: #f5f5f7;
      border-radius: 8px;
      padding: 20px;
      text-align: center;
      margin: 20px 0;
    }
    .code {
      font-size: 32px;
      font-weight: 700;
      letter-spacing: 8px;
      color: #6366f1;
    }
    .footer {
      text-align: center;
      padding-top: 30px;
      border-top: 1px solid #e5e5e5;
      margin-top: 30px;
    }
    .footer p {
      font-size: 12px;
      color: #8b8ba3;
    }
    .footer a {
      color: #6366f1;
      text-decoration: none;
    }
    .warning {
      background-color: #fef3cd;
      border-left: 4px solid #f59e0b;
      padding: 12px 16px;
      margin: 20px 0;
      border-radius: 0 8px 8px 0;
    }
    .warning p {
      color: #92400e;
      margin: 0;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="header">
        <a href="{{frontendUrl}}" class="logo">CYNA</a>
      </div>
      <div class="content">
        {{{content}}}
      </div>
      <div class="footer">
        <p>&copy; {{year}} CYNA. All rights reserved.</p>
        <p>Cybersecurity Solutions for Businesses</p>
      </div>
    </div>
  </div>
</body>
</html>
