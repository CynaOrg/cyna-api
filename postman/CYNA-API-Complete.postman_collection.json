            "description": "Verify email address using the token sent via email. Single-use token, no rate limit."
          },
          "response": []
        },
        {
          "name": "Resend Verification",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/auth/resend-verification",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "auth", "resend-verification"]
            },
            "description": "Resend verification email. Rate limited to 2 req/5min."
          },
          "response": []
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "auth", "forgot-password"]
            },
            "description": "Request a password reset email. Rate limited to 3 req/5min."
          },
          "response": []
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<reset-token-from-email>\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "auth", "reset-password"]
            },
            "description": "Reset password using the token from the reset email. Single-use token, no rate limit."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.accessToken) {",
                  "        pm.environment.set('accessToken', json.accessToken);",
                  "        pm.environment.set('tokenExpiresAt', String(Date.now() + (json.expiresIn * 1000)));",
                  "    }",
                  "    pm.test('Token refreshed', () => pm.response.to.have.status(200));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "auth", "refresh-token"]
            },
            "description": "Refresh access token. Reads refresh token from HTTP-only cookie automatically. Rate limited to 10 req/min."
          },
          "response": []
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.environment.set('accessToken', '');",
                  "    pm.environment.set('refreshToken', '');",
                  "    pm.environment.set('tokenExpiresAt', '0');",
                  "    pm.test('Logout successful', () => pm.response.to.have.status(200));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "auth", "logout"]
            },
            "description": "Logout user. Requires Bearer token. Clears refresh token cookie. Rate limited to 5 req/min."
          },
          "response": []
