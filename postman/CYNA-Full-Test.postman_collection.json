{
  "info": {
    "name": "CYNA - Full Test Collection",
    "description": "Collection complète avec scripts automatiques pour tester CYNA API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "tempToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminEmail",
      "value": "admin@cyna.io",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "AdminPassword123!",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    },
    {
      "key": "imageId",
      "value": "",
      "type": "string"
    },
    {
      "key": "characteristicId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth Flow",
      "item": [
        {
          "name": "1. Admin Login (Get tempToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    var data = jsonData.data || jsonData;",
                  "    if (data.tempToken) {",
                  "        pm.collectionVariables.set('tempToken', data.tempToken);",
                  "        console.log('✅ tempToken saved:', data.tempToken.substring(0, 50) + '...');",
                  "        console.log('📧 Check database for 2FA code');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/admin/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "admin", "login"]
            }
          }
        },
        {
          "name": "2. Verify 2FA (Use code from DB)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    var data = jsonData.data || jsonData;",
                  "    if (data.accessToken) {",
                  "        pm.collectionVariables.set('adminToken', data.accessToken);",
                  "        console.log('✅ adminToken saved!');",
                  "        console.log('🎉 You can now use admin endpoints');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Get tempToken from collection variables",
                  "var tempToken = pm.collectionVariables.get('tempToken');",
                  "if (!tempToken) {",
                  "    console.warn('⚠️ No tempToken found. Run Admin Login first.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tempToken\": \"{{tempToken}}\",\n  \"code\": \"REPLACE_WITH_CODE_FROM_DB\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/admin/verify-2fa",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "admin", "verify-2fa"]
            }
          }
        }
      ]
    },
