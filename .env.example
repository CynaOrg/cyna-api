# Application
NODE_ENV=development
APP_NAME=cyna-api
APP_PORT=3000

# API Configuration
API_PREFIX=api
API_VERSION=v1

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# i18n
DEFAULT_LANGUAGE=fr
FALLBACK_LANGUAGE=en

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:8100

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=cyna
DATABASE_PASSWORD=cyna_dev
DATABASE_NAME=cyna_db
DATABASE_SYNC=false
DATABASE_LOGGING=true

# Redis
# REDIS_URL takes priority if set (e.g. on Railway: redis://default:password@host:6379)
# REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_TTL=3600

# SMTP (Notification Service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@cyna.io
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=CYNA
SMTP_FROM_EMAIL=noreply@cyna.io

# URLs Frontend (Notification Service)
FRONTEND_URL=http://localhost:4200
BACKOFFICE_URL=http://localhost:4201

# Auth Service - JWT
JWT_SECRET=change-me-in-production-minimum-32-characters!!
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Auth Service - Bcrypt
BCRYPT_SALT_ROUNDS=12

# Auth Service - 2FA
TWO_FACTOR_CODE_EXPIRY_MINUTES=5

# Catalog Service - Stock Management
STOCK_RESERVATION_EXPIRY_MINUTES=15
STOCK_ALERT_DEFAULT_THRESHOLD=10

# Cloudflare R2 (Product Images)
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=cyna-product-images
R2_PUBLIC_URL=https://pub-xxx.r2.dev
R2_REGION=auto
