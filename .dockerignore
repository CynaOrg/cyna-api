# Node
node_modules
npm-debug.log*

# Build artefacts (regenerated inside the image)
dist
coverage
.turbo
.cache

# Tests (not needed at runtime)
**/*.spec.ts
**/*.e2e-spec.ts
test
**/__tests__
**/__mocks__
jest.config.js

# IDE / editor
.vscode
.idea
*.swp

# Git & CI
.git
.gitignore
.github

# Local env files — NEVER ship to image
.env
.env.*
!.env.example
!.env.development

# Docs / OpenAPI artefacts
docs
openapi.json
postman

# Docker (avoid recursion)
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# OS junk
.DS_Store
Thumbs.db
