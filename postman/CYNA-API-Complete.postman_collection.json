    {
      "name": "Auth - Admin",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.tempToken) {",
                  "        pm.environment.set('tempToken', json.tempToken);",
                  "    }",
                  "    pm.test('2FA code sent', () => {",
                  "        pm.expect(json.requires2FA).to.be.true;",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/auth/admin/login",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "auth", "admin", "login"]
            },
            "description": "Admin login Step 1: Sends a 2FA code to the admin's email. Returns a tempToken for Step 2. Rate limited to 5 req/min."
          },
          "response": []
        },
