{
  "name": "cyna-api",
  "version": "1.0.0",
  "description": "CYNA - B2B Cybersecurity E-commerce Platform API",
  "author": "CYNA Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api-gateway/main",
    "start:dev:gateway": "nest start api-gateway --watch",
    "start:dev:notification": "nest start notification-service --watch",
    "start:dev:auth": "nest start auth-service --watch",
    "start:dev:catalog": "nest start catalog-service --watch",
    "start:dev:order": "nest start order-service --watch",
    "start:dev:payment": "nest start payment-service --watch",
    "start:dev:content": "nest start content-service --watch",
    "start:dev:analytics": "nest start analytics-service --watch",
    "start:dev:all": "concurrently -n gateway,auth,catalog,order,payment,notification,content,analytics -c blue,green,cyan,magenta,red,yellow,white,gray \"npm run start:dev:gateway\" \"npm run start:dev:auth\" \"npm run start:dev:catalog\" \"npm run start:dev:order\" \"npm run start:dev:payment\" \"npm run start:dev:notification\" \"npm run start:dev:content\" \"npm run start:dev:analytics\"",
    "start:infra": "docker-compose up -d",
    "start:all": "npm run start:infra && npm run start:dev:all",
    "stop:infra": "docker-compose down",
    "lint": "eslint \"apps/**/*.ts\" \"libs/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/api-gateway/test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.989.0",
    "@aws-sdk/s3-request-presigner": "^3.989.0",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.5",
    "bcrypt": "^5.1.1",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "handlebars": "^4.7.8",
    "helmet": "^8.0.0",
    "ioredis": "^5.9.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "nest-winston": "^1.10.2",
    "nestjs-i18n": "^10.5.0",
    "nodemailer": "^6.9.8",
    "pg": "^8.17.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^20.3.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "uuid": "^11.0.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/amqplib": "^0.10.5",
    "@types/bcrypt": "^5.0.2",
    "@types/cache-manager-redis-store": "^2.0.4",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@cyna-api/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@cyna-api/s3(|/.*)$": "<rootDir>/libs/s3/src/$1"
    }
  }
}
